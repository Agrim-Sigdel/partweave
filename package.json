{
  "name": "quick-build",
  "version": "0.1.0",
  "private": true,
  "description": "A modular full-stack scaffolding platform — pick the parts you need (Django server, Next.js web, Expo mobile) and generate only that code, wired together.",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter @quick-build/cli build",
    "dev": "pnpm --filter @quick-build/cli dev",
    "cli": "pnpm --filter @quick-build/cli exec quick-build",
    "create": "pnpm --filter @quick-build/cli exec create-quick-build",
    "test": "pnpm --filter @quick-build/cli test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
