{
  "name": "partweave-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "A modular full-stack scaffolding platform — pick the parts you need (Django server, Next.js web, Expo mobile) and generate only that code, wired together.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Agrim Sigdel <sigdelagrim35@gmail.com>",
  "packageManager": "pnpm@10.20.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter partweave build",
    "dev": "pnpm --filter partweave dev",
    "cli": "pnpm --filter partweave exec partweave",
    "create": "pnpm --filter partweave exec create-partweave",
    "test": "pnpm --filter partweave test",
    "typecheck": "pnpm -r typecheck",
    "release": "pnpm --filter partweave exec npm version",
    "website": "pnpm --filter website dev"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
