#!/usr/bin/env bash
# Thin launcher for the quick-build CLI. Builds on first run, then execs it.
# Usage: ./bin/quick-build create   |   ./bin/quick-build add <component>
set -euo pipefail

# Resolve symlinks so this works whether run in-repo or via a symlinked launcher
# (e.g. ~/.local/bin/quick-build -> ~/.quick-build/bin/quick-build).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  LINK_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$LINK_DIR/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
CLI="$DIR/packages/cli/dist/index.js"

if [ ! -f "$CLI" ]; then
  echo "▸ First run — installing dependencies and building the CLI…" >&2
  command -v pnpm >/dev/null 2>&1 || corepack enable >/dev/null 2>&1 || true
  # Prefer pnpm; fall back to npm so a machine without pnpm still works.
  if command -v pnpm >/dev/null 2>&1; then
    (cd "$DIR" && pnpm install && pnpm --filter quick-build build) >&2
  elif command -v npm >/dev/null 2>&1; then
    (cd "$DIR" && npm install && npm run build -w quick-build) >&2
  else
    echo "✗ need pnpm or npm to build the CLI (both come with Node)" >&2
    exit 1
  fi
fi

exec node "$CLI" "$@"
