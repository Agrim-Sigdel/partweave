# deps
node_modules/
.pnpm-store/

# build output
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# python (only in generated projects, but ignore here too for safety)
__pycache__/
*.pyc
.venv/
venv/

# os / editor
.DS_Store
*.log
.idea/
.vscode/*
!.vscode/extensions.json

# generator scratch / e2e output
/.out/
/tmp-e2e/

