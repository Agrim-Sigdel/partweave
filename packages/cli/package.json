{
  "name": "@base/cli",
  "version": "0.1.0",
  "description": "The base generator — compose a full-stack project from selectable modules.",
  "type": "module",
  "bin": {
    "create-base-app": "dist/create-bin.js",
    "base-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "../../modules"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
