{
  "name": "partweave",
  "version": "0.5.0",
  "description": "A modular full-stack scaffolder — pick the parts you need (Django server, Next.js web, Expo mobile) and generate only that code, wired together.",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "Agrim Sigdel <sigdelagrim35@gmail.com>",
  "homepage": "https://github.com/Agrim-Sigdel/partweave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agrim-Sigdel/partweave.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Agrim-Sigdel/partweave/issues"
  },
  "keywords": [
    "scaffold",
    "scaffolder",
    "generator",
    "boilerplate",
    "full-stack",
    "django",
    "nextjs",
    "expo",
    "monorepo",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "partweave": "dist/index.js",
    "weave": "dist/index.js",
    "create-partweave": "dist/create-bin.js"
  },
  "files": [
    "dist/**/*.js",
    "modules/**",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bundle-modules": "node scripts/bundle-modules.mjs",
    "prepack": "npm run build && npm run bundle-modules",
    "postpack": "node scripts/bundle-modules.mjs --clean"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "tar": "^7.5.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/tar": "^7.0.87",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
