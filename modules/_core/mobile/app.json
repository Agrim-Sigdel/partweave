{
  "expo": {
    "name": "{{projectName}}",
    "slug": "{{projectSlug}}",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "{{projectSlug}}",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "{{packageId}}"
    },
    "plugins": ["expo-router"]
  }
}
